# Copia este archivo como .env.local y rellena los valores.
# NUNCA commitear .env.local — está en .gitignore.

# ---------- Supabase ----------
NEXT_PUBLIC_SUPABASE_URL=https://pvytlgnkdodhafzuqrhm.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ROTAR ANTES DE USAR: la service_role_key anterior quedó expuesta en chat.
# Project Settings → API → "Reset service_role secret" en Supabase, luego pegar aquí.
SUPABASE_SERVICE_ROLE_KEY=

# ---------- App ----------
APP_TIMEZONE=America/Guatemala
APP_NAME=Quiniela Mundial 2026
APP_URL=http://localhost:3000

# ---------- Cron / cierre automático ----------
# Genera con:  openssl rand -hex 32   (o en PowerShell)
CRON_SECRET=

# ---------- Opcional: rate limiting (Upstash) ----------
# Si están vacíos, el rate limit queda deshabilitado (no rompe la app).
# Crear DB gratuita en https://console.upstash.com/redis (10K req/día).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---------- Opcional: CAPTCHA en login (Cloudflare Turnstile) ----------
# Si están vacíos, el widget no aparece y el login funciona sin CAPTCHA.
# Setup:
#   1) https://dash.cloudflare.com → Turnstile → Add site (gratis)
#   2) Pegá el "Site key" público acá:
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
#   3) En Supabase dashboard → Auth → CAPTCHA → activar Turnstile y pegar el "Secret key".
#      (Supabase valida el token; no necesitamos secret en esta app.)
